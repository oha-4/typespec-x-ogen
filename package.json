{
  "name": "typespec-x-ogen",
  "version": "1.0.1",
  "description": "TypeSpec decorators for ogen (https://ogen.dev) OpenAPI vendor extensions (x-ogen-*).",
  "keywords": [
    "typespec",
    "openapi",
    "ogen",
    "extensions",
    "decorators"
  ],
  "license": "MIT",
  "author": "Yoshito Ohata",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oha-4/typespec-x-ogen.git"
  },
  "bugs": {
    "url": "https://github.com/oha-4/typespec-x-ogen/issues"
  },
  "homepage": "https://github.com/oha-4/typespec-x-ogen#readme",
  "type": "module",
  "main": "dist/src/index.js",
  "tspMain": "lib/main.tsp",
  "exports": {
    ".": {
      "typespec": "./lib/main.tsp",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "lib/**/*.tsp",
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . --watch",
    "clean": "rm -rf dist tsp-output coverage",
    "link:self": "node scripts/link-self.mjs",
    "format": "prettier --write . && tsp format \"lib/**/*.tsp\" \"samples/**/*.tsp\"",
    "format:check": "prettier --check . && tsp format --check \"lib/**/*.tsp\" \"samples/**/*.tsp\"",
    "pretest": "npm run link:self",
    "test": "npm run build && vitest run",
    "test:watch": "npm run link:self && vitest",
    "coverage": "npm run build && npm run link:self && vitest run --coverage",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "yaml": "^2.7.0"
  },
  "peerDependencies": {
    "@typespec/compiler": ">=1.12.0 <2.0.0",
    "@typespec/openapi": ">=1.12.0 <2.0.0",
    "@typespec/openapi3": ">=1.12.0 <2.0.0"
  },
  "devDependencies": {
    "@typespec/compiler": "^1.12.0",
    "@typespec/http": "^1.12.0",
    "@typespec/openapi": "^1.12.0",
    "@typespec/openapi3": "^1.12.0",
    "@vitest/coverage-v8": "^4.1.0",
    "prettier": "^3.8.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
